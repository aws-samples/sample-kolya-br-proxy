# Environment mode: non-prod or prod
KBR_ENV=non-prod

# Debug mode (true for development, false for production)
KBR_DEBUG=true

# Server port
KBR_PORT=8000

# Database connection URL (PostgreSQL with asyncpg driver)
KBR_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/kolyabrproxy  # pragma: allowlist secret

# JWT configuration
KBR_JWT_SECRET_KEY=your-secret-key-min-32-characters-long
KBR_JWT_ALGORITHM=HS256
KBR_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
KBR_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS allowed origins (comma-separated)
KBR_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:9000

# AWS configuration
KBR_AWS_REGION=us-west-2

# AWS Bedrock configuration
KBR_BEDROCK_MAX_CONCURRENT_REQUESTS=50
# Rate limiting: set your Bedrock account RPM quota (check AWS Service Quotas)
# Redis mode:  global rate = account_rpm / 60 (all pods share one bucket)
# Local mode:  per-pod rate = account_rpm / 60 / expected_pods
KBR_BEDROCK_ACCOUNT_RPM=500
KBR_BEDROCK_EXPECTED_PODS=3
KBR_BEDROCK_RATE_BURST=10
# Auto-inject prompt cache breakpoints for Anthropic models (default: true)
# Set to false if most workloads are one-shot calls to avoid 25% write premium
# KBR_PROMPT_CACHE_AUTO_INJECT=true
# Prompt cache TTL: "5m" (default Anthropic) or "1h" (extended, recommended for long sessions)
# KBR_PROMPT_CACHE_TTL=1h
# Redis configuration (distributed rate limiting across Pods)
# When set, rate limiting uses Redis for global coordination
# Falls back to per-pod memory rate limiting when Redis is unavailable
# KBR_REDIS_URL=redis://localhost:6379/0

# Database connection pool settings
KBR_DATABASE_POOL_SIZE=10
KBR_DATABASE_MAX_OVERFLOW=20

# User configuration
KBR_INITIAL_USER_BALANCE_USD=0.0

# Logging
# KBR_LOG_LEVEL=INFO

# Email whitelist (set to true to restrict registration to whitelisted emails)
# KBR_EMAIL_WHITELIST_ENABLED=false

# Uvicorn server settings
KBR_UVICORN_TIMEOUT_KEEP_ALIVE=3700
KBR_UVICORN_LIMIT_CONCURRENCY=100
KBR_UVICORN_LIMIT_MAX_REQUESTS=0

# Streaming settings
KBR_STREAM_HEARTBEAT_INTERVAL=15

# Microsoft OAuth configuration
KBR_MICROSOFT_CLIENT_ID=your-client-id
KBR_MICROSOFT_CLIENT_SECRET=your-client-secret
KBR_MICROSOFT_TENANT_ID=your-tenant-id
KBR_MICROSOFT_REDIRECT_URIS=http://localhost:9000/auth/microsoft/callback

# AWS Cognito OAuth configuration (optional)
# KBR_COGNITO_USER_POOL_ID=us-west-2_abc123def
# KBR_COGNITO_CLIENT_ID=your-cognito-client-id
# KBR_COGNITO_CLIENT_SECRET=your-cognito-client-secret
# KBR_COGNITO_REGION=us-west-2
# KBR_COGNITO_DOMAIN=your-cognito-domain-prefix
# KBR_COGNITO_REDIRECT_URIS=http://localhost:9000/auth/cognito/callback
