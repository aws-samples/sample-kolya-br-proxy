# Example configuration for enabling Cognito
# Copy relevant sections to your terraform.tfvars file

# AWS Configuration
account = "612674025488"
region  = "us-west-2"

# Enable Cognito authentication
enable_cognito = true

# Cognito OAuth callback URLs
# Add all URLs where users can be redirected after authentication
cognito_callback_urls = [
  "http://localhost:9000/auth/cognito/callback",           # Local development
  "https://kbp.kolya.fun/auth/cognito/callback"            # Production
]

# Cognito logout URLs
# Add all URLs where users can be redirected after logout
cognito_logout_urls = [
  "http://localhost:9000",                                  # Local development
  "https://kbp.kolya.fun"                                   # Production
]

# Token validity settings (optional, defaults shown)
cognito_access_token_validity  = 60    # minutes
cognito_id_token_validity      = 60    # minutes
cognito_refresh_token_validity = 30    # days
