# Kolya BR Proxy Frontend - Environment Variables
#
# This file shows all available environment variables.
# Copy to .env for local development or use .env.development / .env.production
#
# Quasar/Vite will automatically load:
# - .env.development when running 'quasar dev'
# - .env.production when running 'quasar build'
#
# Note: All client-side variables must be prefixed with VITE_ to be exposed by Vite

# API Base URL
VITE_API_BASE_URL=http://localhost:8000

# Microsoft OAuth Redirect URI
VITE_MICROSOFT_REDIRECT_URI=http://localhost:9000/auth/microsoft/callback
