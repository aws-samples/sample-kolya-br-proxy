apiVersion: v1
kind: ServiceAccount
metadata:
  name: backend
  namespace: kbp
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: backend
  namespace: kbp
  labels:
    app: backend
spec:
  replicas: 2
  selector:
    matchLabels:
      app: backend
  template:
    metadata:
      labels:
        app: backend
    spec:
      serviceAccountName: backend
      nodeSelector:
        karpenter.sh/nodepool: common-nodepool
      initContainers:
      - name: db-migrate
        image: ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/kolya-br-proxy-backend:latest
        command: ["python", "scripts/migrate.py"]
        workingDir: /app/backend
        envFrom:
        - configMapRef:
            name: backend-config
        env:
        - name: KBR_DATABASE_URL
          valueFrom:
            secretKeyRef:
              name: backend-secrets
              key: database-url
        - name: KBR_JWT_SECRET_KEY
          valueFrom:
            secretKeyRef:
              name: backend-secrets
              key: jwt-secret-key
      containers:
      - name: backend
        image: ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/kolya-br-proxy-backend:latest
        imagePullPolicy: Always
        ports:
        - containerPort: 8000
          name: http
        envFrom:
        - configMapRef:
            name: backend-config
        env:
        - name: KBR_DATABASE_URL
          valueFrom:
            secretKeyRef:
              name: backend-secrets
              key: database-url
        - name: KBR_JWT_SECRET_KEY
          valueFrom:
            secretKeyRef:
              name: backend-secrets
              key: jwt-secret-key
        - name: KBR_MICROSOFT_CLIENT_ID
          valueFrom:
            secretKeyRef:
              name: backend-secrets
              key: microsoft-client-id
        - name: KBR_MICROSOFT_CLIENT_SECRET
          valueFrom:
            secretKeyRef:
              name: backend-secrets
              key: microsoft-client-secret
        - name: KBR_MICROSOFT_TENANT_ID
          valueFrom:
            secretKeyRef:
              name: backend-secrets
              key: microsoft-tenant-id
        - name: KBR_COGNITO_USER_POOL_ID
          valueFrom:
            secretKeyRef:
              name: backend-secrets
              key: cognito-user-pool-id
        - name: KBR_COGNITO_CLIENT_ID
          valueFrom:
            secretKeyRef:
              name: backend-secrets
              key: cognito-client-id
        - name: KBR_COGNITO_CLIENT_SECRET
          valueFrom:
            secretKeyRef:
              name: backend-secrets
              key: cognito-client-secret
        - name: KBR_COGNITO_REGION
          valueFrom:
            secretKeyRef:
              name: backend-secrets
              key: cognito-region
        - name: KBR_GEMINI_API_KEY
          valueFrom:
            secretKeyRef:
              name: backend-secrets
              key: gemini-api-key
              optional: true
        resources:
          requests:
            cpu: ${BACKEND_CPU_REQUEST}
            memory: ${BACKEND_MEMORY_REQUEST}
          limits:
            cpu: ${BACKEND_CPU_LIMIT}
            memory: ${BACKEND_MEMORY_LIMIT}
        livenessProbe:
          httpGet:
            path: /health/
            port: 8000
          initialDelaySeconds: 60
          periodSeconds: 10
          timeoutSeconds: 5
          failureThreshold: 3
        readinessProbe:
          httpGet:
            path: /health/
            port: 8000
          initialDelaySeconds: 30
          periodSeconds: 10
          timeoutSeconds: 3
          failureThreshold: 2
