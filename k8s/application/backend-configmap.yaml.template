apiVersion: v1
kind: ConfigMap
metadata:
  name: backend-config
  namespace: kbp
data:
  KBR_ENV: "${KBR_ENV}"
  KBR_DEBUG: "false"
  KBR_PORT: "8000"
  KBR_AWS_REGION: "${AWS_REGION}"
  KBR_JWT_ALGORITHM: "HS256"
  KBR_JWT_ACCESS_TOKEN_EXPIRE_MINUTES: "30"
  KBR_JWT_REFRESH_TOKEN_EXPIRE_DAYS: "7"
  KBR_INITIAL_USER_BALANCE_USD: "0.0"
  KBR_LOG_LEVEL: "INFO"
  KBR_ALLOWED_ORIGINS: "https://${FRONTEND_DOMAIN},https://${API_DOMAIN}${API_PORT_SUFFIX}"
  KBR_MICROSOFT_REDIRECT_URIS: "https://${FRONTEND_DOMAIN}/auth/microsoft/callback"
  KBR_COGNITO_REDIRECT_URIS: "https://${FRONTEND_DOMAIN}/auth/cognito/callback"
  # AWS Cognito OAuth configuration (domain derived from FRONTEND_DOMAIN)
  KBR_COGNITO_DOMAIN: "${COGNITO_DOMAIN}"
  KBR_DATABASE_POOL_SIZE: "10"
  KBR_DATABASE_MAX_OVERFLOW: "20"
  KBR_EMAIL_WHITELIST_ENABLED: "false"
  # Uvicorn server settings
  KBR_UVICORN_TIMEOUT_KEEP_ALIVE: "3600"
  KBR_UVICORN_LIMIT_CONCURRENCY: "100"
  KBR_UVICORN_LIMIT_MAX_REQUESTS: "10000"
  # Streaming settings
  KBR_STREAM_HEARTBEAT_INTERVAL: "15"
  # Bedrock request control (token bucket + semaphore)
  # Redis mode: global rate = account_rpm / 60 (shared across all pods)
  # Local mode: per-pod rate = account_rpm / 60 / expected_pods
  KBR_BEDROCK_MAX_CONCURRENT_REQUESTS: "50"
  KBR_BEDROCK_ACCOUNT_RPM: "500"
  KBR_BEDROCK_EXPECTED_PODS: "3"
  KBR_BEDROCK_RATE_BURST: "10"
  # Auto-inject prompt cache breakpoints for Anthropic models
  KBR_PROMPT_CACHE_AUTO_INJECT: "true"
  # Prompt cache TTL: "5m" or "1h" (extended, reduces cache misses in long sessions)
  KBR_PROMPT_CACHE_TTL: "1h"
  # Redis configuration (distributed rate limiting)
  KBR_REDIS_URL: "redis://redis-master.kbp.svc.cluster.local:6379/0"
